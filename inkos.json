{
  "name": "xiaoshuo",
  "version": "0.1.0",
  "language": "zh",
  "llm": {
    "provider": "openai",
    "service": "siliconcloud",
    "configSource": "project",
    "baseUrl": "https://api.siliconflow.cn/v1",
    "model": "deepseek-ai/DeepSeek-V4-Pro",
    "apiFormat": "chat",
    "stream": true,
    "services": [
      {
        "service": "custom",
        "name": "DeepSeek (Anthropic 兼容)",
        "baseUrl": "https://api.deepseek.com/anthropic",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true
      },
      {
        "service": "deepseek",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true
      },
      {
        "service": "siliconcloud",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true
      }
    ],
    "defaultModel": "deepseek-ai/DeepSeek-V4-Pro",
    "temperature": 0.7
  },
  "notify": [],
  "inputGovernanceMode": "v2",
  "daemon": {
    "schedule": {
      "radarCron": "0 */6 * * *",
      "writeCron": "*/15 * * * *"
    },
    "maxConcurrentBooks": 3
  }
}